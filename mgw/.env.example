# ─────────────────────────────────────────────────────────────
# MGW Platform — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────────
# Used in sitemap.xml and robots.txt for canonical URLs.
# Set to your deployed domain when in production.
VITE_SITE_URL=https://mgw.mavingrandpa.com

# ── Paystack (Payment Processing) ────────────────────────────
# Your Paystack public key — safe to expose on the frontend.
# Get it from: https://dashboard.paystack.com/#/settings/developer
# Use the test key (pk_test_...) during development.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Zoom (Automated Meeting Creation) ────────────────────────
# Used by server.js (backend only — never exposed to the browser).
# Create a Server-to-Server OAuth app at: https://marketplace.zoom.us/
# Required scopes: meeting:write:admin
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ── Admin Credentials (optional hardening) ───────────────────
# Currently the admin email is hardcoded as admin@mgw.com.
# Set this if you move admin auth to an env-driven check.
# ADMIN_EMAIL=admin@mgw.com
# ADMIN_PASSWORD=change_me_in_production
